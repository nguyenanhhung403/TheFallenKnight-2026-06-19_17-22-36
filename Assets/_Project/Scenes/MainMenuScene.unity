  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 3ceded6a7978b9241b4f7708433758d3, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::StoryCutsceneController
  storyPanel: {fileID: 1727395246}
  slideshowText: {fileID: 945986850}
  videoDisplay: {fileID: 1075015262}
  videoPlayer: {fileID: 286033587}
  creditsContainer: {fileID: 311792555}
  creditsText: {fileID: 311792552}
  mainMenuCanvasGroup: {fileID: 509397669}
  introClip: {fileID: 32900000, guid: 76390cad86aa8c948b69ad69af42df36, type: 3}
  redemptionClip: {fileID: 32900000, guid: 00c875a9acfa7ed459e34546ca7592cd, type: 3}
  legacyClip: {fileID: 32900000, guid: 4db9b9be2902ab3429b534518cd6d045, type: 3}
  introSlides:
  - "H\xE0ng ngh\xECn n\u0103m tr\u01B0\u1EDBc, Tr\xE1ng S\u0129 S\u01A1n Nam l\xE0
    v\u1ECB anh h\xF9ng oai h\xF9ng \u0111\xE3 \u0111\xE1nh tan gi\u1EB7c ngo\u1EA1i
    x\xE2m ph\u01B0\u01A1ng B\u1EAFc v\xE0 b\u1EA3o v\u1EC7 b\u1EDD c\xF5i \u0110\u1EA1i
    Vi\u1EC7t."
  - "Sau th\u1EAFng l\u1EE3i v\u1EBB vang, do mang n\u1EE3 m\xE1u chi\u1EBFn tr\u1EADn,
    vong h\u1ED3n \xF4ng kh\xF4ng th\u1EC3 si\xEAu tho\xE1t, l\u01B0u l\u1EA1c nh\xE2n
    gian su\u1ED1t nhi\u1EC1u tri\u1EC1u \u0111\u1EA1i."
  - "Theo th\u1EDDi gian, t\xE2m tr\xED \xF4ng d\u1EA7n b\u1ECB t\xE0 kh\xED x\xE2m
    chi\u1EBFm, \u1EA3o t\u01B0\u1EDFng r\u1EB1ng chi\u1EBFn tranh v\u1EABn ch\u01B0a
    k\u1EBFt th\xFAc."
  - "Ng\u01B0\u1EDDi anh h\xF9ng n\u0103m x\u01B0a gi\u1EDD tr\u1EDF th\xE0nh m\u1ED1i
    hi\u1EC3m h\u1ECDa \u0111e d\u1ECDa b\u1EDD c\xF5i b\xECnh y\xEAn c\u1EE7a n\u01B0\u1EDBc
    nh\xE0."
  - "Ng\u01B0\u1EDDi ch\u01A1i v\xE0o vai c\u1EADu h\u1ECDc tr\xF2 ngh\xE8o mang
    trong m\xECnh d\xF2ng m\xE1u anh h\xF9ng 'H\xE0o Kh\xED \u0110\xF4ng A'..."
  - "...v\u1EDBi l\xF2ng y\xEAu n\u01B0\u1EDBc n\u1ED3ng n\xE0n v\xE0 \xFD ch\xED
    b\u1EA5t khu\u1EA5t, quy\u1EBFt t\xE2m th\u1EE9c t\u1EC9nh Tr\xE1ng S\u0129 S\u01A1n
    Nam kh\u1ECFi c\u01A1n u m\xEA ng\xE0n n\u0103m!"
  redemptionSlides:
  - "L\u1EDDi ru \u0111\u1EA5t m\u1EB9 d\u1ECBu \xEAm vang v\u1ECDng..."
  - "H\xE0o Kh\xED \u0110\xF4ng A \u0111\xE3 thanh t\u1EA9y t\xE0 kh\xED, gi\xFAp
    tr\xE1ng s\u0129 S\u01A1n Nam tr\xFAt b\u1ECF g\u01B0\u01A1m \u0111ao, m\u1EC9m
    c\u01B0\u1EDDi si\xEAu tho\xE1t."
  - "\u0110\u1EA5t n\u01B0\u1EDBc thanh b\xECnh vang ti\u1EBFng ca th\xE1i b\xECnh
    th\u1ECBnh tr\u1ECB!"
  legacySlides:
  - "Tr\xE1ng s\u0129 ng\xE3 xu\u1ED1ng, nh\u01B0ng t\xE0 ni\u1EC7m chi\u1EBFn tranh
    v\u1EABn ch\u01B0a ch\u1ECBu tan bi\u1EBFn."
  - "C\u1EA7m l\u1EA5y thanh th\u1EA7n ki\u1EBFm v\u01B0\u01A1ng \u0111\u1EA7y h\u1EAFc
    kh\xED, c\u1EADu thi\u1EBFu ni\xEAn b\u1ECB b\xF3ng t\u1ED1i nu\u1ED1t ch\u1EEDng,
    tr\u1EDF th\xE0nh h\u1ED9 v\u1EC7 m\u1EDBi c\u1EE7a c\xF5i u minh."
  - "V\xF2ng l\u1EB7p gi\u1EB7c gi\xE3 v\xE0 th\xF9 h\u1EADn l\u1EA1i b\u1EAFt \u0111\u1EA7u..."
