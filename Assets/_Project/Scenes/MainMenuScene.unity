--- !u!114 &319379998
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 319379996}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 3ceded6a7978b9241b4f7708433758d3, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::StoryCutsceneController
  storyPanel: {fileID: 927636551}
  slideshowText: {fileID: 372367643}
  videoDisplay: {fileID: 425077992}
  videoPlayer: {fileID: 319379997}
  creditsContainer: {fileID: 1743554183}
  creditsText: {fileID: 1743554180}
  mainMenuCanvasGroup: {fileID: 1977566958}
  introClip: {fileID: 32900000, guid: 76390cad86aa8c948b69ad69af42df36, type: 3}
  redemptionClip: {fileID: 32900000, guid: 00c875a9acfa7ed459e34546ca7592cd, type: 3}
  legacyClip: {fileID: 32900000, guid: 4db9b9be2902ab3429b534518cd6d045, type: 3}
  introSlides:
  - "H\xE0ng ngh\xECn n\u0103m tr\u01B0\u1EDBc, Hi\u1EC7p s\u0129 Th\xE1nh Aurelius
    l\xE0 ng\u01B0\u1EDDi anh h\xF9ng \u0111\xE3 \u0111\xE1nh b\u1EA1i Qu\u1EF7 V\u01B0\u01A1ng
    v\xE0 c\u1EE9u l\u1EA5y l\u1EE5c \u0111\u1ECBa Elyndor."
  - "Sau chi\u1EBFn th\u1EAFng, c\xE1c v\u1ECB th\u1EA7n t\u1EEB ch\u1ED1i \u0111\u01B0a
    \xF4ng l\xEAn Thi\xEAn Gi\u1EDBi v\xEC linh h\u1ED3n \xF4ng \u0111\u01B0\u1EE3c
    sinh ra t\u1EEB chi\u1EBFn tranh v\xE0 m\xE1u \u0111\u1ED5."
  - "Kh\xF4ng th\u1EC3 ch\u1EBFt, c\u0169ng kh\xF4ng th\u1EC3 \u0111\u01B0\u1EE3c
    c\u1EE9u r\u1ED7i, Aurelius lang thang su\u1ED1t nhi\u1EC1u th\u1EBF k\u1EF7."
  - "Qua th\u1EDDi gian, kh\xE1t v\u1ECDng b\u1EA3o v\u1EC7 nh\xE2n lo\u1EA1i d\u1EA7n
    bi\u1EBFn th\xE0nh c\u01A1n \xE1m \u1EA3nh ph\u1EA3i chi\u1EBFn \u0111\u1EA5u
    kh\xF4ng ng\u1EEBng. \xD4ng tin r\u1EB1ng ch\u1EC9 c\xF3 chi\u1EBFn tranh m\u1EDBi
    gi\u1EEF cho th\u1EBF gi\u1EDBi t\u1ED3n t\u1EA1i."
  - "Ng\u01B0\u1EDDi anh h\xF9ng n\u0103m x\u01B0a d\u1EA7n tr\u1EDF th\xE0nh m\u1ED1i
    hi\u1EC3m h\u1ECDa l\u1EDBn nh\u1EA5t c\u1EE7a nh\xE2n lo\u1EA1i."
  - "Ng\u01B0\u1EDDi ch\u01A1i v\xE0o vai The Nameless \u2013 m\u1ED9t chi\u1EBFn
    binh tr\u1EBB mang trong m\xECnh Soul of Dawn..."
  - "...linh h\u1ED3n \u0111\u01B0\u1EE3c c\xE1c v\u1ECB th\u1EA7n t\u1EA1o ra nh\u1EB1m
    ch\u1EA5m d\u1EE9t v\xF2ng l\u1EB7p chi\u1EBFn tranh v\xE0 gi\u1EA3i tho\xE1t
    cho Hi\u1EC7p s\u0129 Th\xE1nh."
  redemptionSlides:
  - "Tr\u1EADn chi\u1EBFn sinh t\u1EED k\u1EBFt th\xFAc..."
  - "The Nameless \u0111\xE3 gi\u1EA3i tho\xE1t th\xE0nh c\xF4ng linh h\u1ED3n Hi\u1EC7p
    s\u0129 Th\xE1nh Aurelius."
  - "B\xF3ng t\u1ED1i \u0111ang d\u1EA7n b\u1ECB thanh t\u1EA9y b\u1EDFi h\xE0o quang
    c\u1EE9u th\u1EBF c\u1EE7a Soul of Dawn..."
  legacySlides:
  - "Hi\u1EC7p s\u0129 Th\xE1nh \u0111\xE3 ng\xE3 xu\u1ED1ng..."
  - "Nh\u01B0ng t\xE0n d\u01B0 b\xF3ng t\u1ED1i v\u1EABn qu\u1EA9n quanh v\xE0 t\xECm
    ki\u1EBFm ch\u1EE7 nh\xE2n m\u1EDBi."
  - "V\xF2ng l\u1EB7p v\xF4 t\u1EADn c\u1EE7a chi\u1EBFn tranh v\xE0 th\xF9 h\u1EADn
    l\u1EA1i ti\u1EBFp di\u1EC5n..."
